<!-- Formulario para agregar país nuevo-->
<div class="max-w-xl mx-auto px-4 py-6">
    <div class="mb-4">
        <a href="/countries" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-900 transition-colors">&larr; Volver al dashboard</a>
    </div>
    <form id="addCountryForm" action="" method="POST" class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col gap-4">
            <div class="flex flex-col gap-1">
            <% if (errors['nombre.oficial']) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors['nombre.oficial'] %></p>
                <label for="nombre.oficial" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Nombre Oficial:</label>
                <input type="text" id="nombre.oficial" name="nombre.oficial" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData['nombre.oficial'] %>" required>
            <% } else { %>
                <label for="nombre.oficial" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Nombre Oficial:</label>
                <input type="text" id="nombre.oficial" name="nombre.oficial" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" value="<%= oldData['nombre.oficial'] %>" required>
            <% } %>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors['nombre.comun']) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors['nombre.comun'] %></p>
                <label for="nombre.comun" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Nombre Común:</label>
                <input type="text" id="nombre.comun" name="nombre.comun" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData['nombre.comun'] %>" required>
            <% } else { %>
                <label for="nombre.comun" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Nombre Común:</label>
                <input type="text" id="nombre.comun" name="nombre.comun" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" value="<%= oldData['nombre.comun'] %>" required>
            <% } %>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors.capital) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors.capital %></p>
                <label for="capital" class="text-xs uppercase tracking-wide font-semibold text-red-600">Capital:</label>
                <input type="text" id="capital" name="capital" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData.capital %>" required>
            <% } else { %>
                <label for="capital" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Capital:</label>
                <input type="text" id="capital" name="capital" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" value="<%= oldData.capital %>" required>
            <% } %>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors['fronterasItem']) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors['fronterasItem'] %></p>
                <label for="fronteras" class="text-xs uppercase tracking-wide font-semibold text-red-600">Fronteras:</label>
            <% } else { %>
                <label for="fronteras" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Fronteras:</label>
            <% } %>
            <% const fronteras = oldData.fronteras || [] %>
            <ul>
                <input type="text" id="fronteras" name="fronteras" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" placeholder="País Limítrofe 1" value="<%= fronteras[0] || '' %>">
                <input type="text" id="fronteras" name="fronteras" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" placeholder="País Limítrofe 2" value="<%= fronteras[1] || ''%>">
                <input type="text" id="fronteras" name="fronteras" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" placeholder="País Limítrofe 3" value="<%= fronteras[2] || ''%>">
                <input type="text" id="fronteras" name="fronteras" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" placeholder="País Limítrofe 4" value="<%= fronteras[3] || ''%>">
                <input type="text" id="fronteras" name="fronteras" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" placeholder="País Limítrofe 5" value="<%= fronteras[4] || ''%>">
            </ul>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors.area) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors.area %></p>
                <label for="area" class="text-xs uppercase tracking-wide font-semibold text-red-600">Área:</label>
                <input type="float" id="area" name="area" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData.area %>" required>
            <% } else { %>
                <label for="area" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Área:</label>
                <input type="float" id="area" name="area" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" value="<%= oldData.area %>" required>
            <% } %>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors.gini) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors.gini %></p>
                <label for="gini" class="text-xs uppercase tracking-wide font-semibold text-red-600">Índice de Gini:</label>
                <input type="float" id="gini" name="gini" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData.gini %>">
            <% } else { %>
                <label for="gini" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Índice de Gini:</label>
                <input type="float" id="gini" name="gini" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" value="<%= oldData.gini %>">
            <% } %>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors.poblacion) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors.poblacion %></p>
                <label for="poblacion" class="text-xs uppercase tracking-wide font-semibold text-red-600">Población:</label>
                <input type="number" id="poblacion" name="poblacion" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData.poblacion %>" required>
            <% } else { %>
                <label for="poblacion" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Población:</label>
                <input type="number" min="0" id="poblacion" name="poblacion" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" value="<%= oldData.poblacion %>" required>
            <% } %>
        </div>
        <div class="flex flex-col gap-1">
            <% if (errors.subregion) { %>
                <p class="text-red-800 font-bold"> ▼ <%= errors.subregion %></p>
                <label for="subregion" class="text-xs uppercase tracking-wide font-semibold text-red-600">Sub Región:</label>
                <select type="text" id="subregion" name="subregion" class="border border-red-400 rounded px-2 py-1 text-sm text-red-600 focus:outline-none" value="<%= oldData.subregion %>" required>
                    <option value="">Seleccione una subregión</option>
                    <option value="south america" <%= (oldData.subregion === 'south america') ? 'selected' : '' %>>Sudamérica</option>
                    <option value="caribbean" <%= (oldData.subregion === 'caribbean') ? 'selected' : '' %>>Caribe</option>
                    <option value="central america" <%= (oldData.subregion === 'central america') ? 'selected' : '' %>>Centroamérica</option>
                    <option value="north america" <%= (oldData.subregion === 'north america') ? 'selected' : '' %>>Norteamérica</option>
                </select>
            <% } else { %>
                <label for="subregion" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Sub Región:</label>
                <select id="subregion" name="subregion" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400" required>
                    <option value="">Seleccione una subregión</option>
                    <option value="South America" <%= (oldData.subregion === 'South America') ? 'selected' : '' %>>Sudamérica</option>
                    <option value="Caribbean" <%= (oldData.subregion === 'Caribbean') ? 'selected' : '' %>>Caribe</option>
                    <option value="Central America" <%= (oldData.subregion === 'Central America') ? 'selected' : '' %>>Centroamérica</option>
                    <option value="North America" <%= (oldData.subregion === 'North America') ? 'selected' : '' %>>Norteamérica</option>
                </select>
            <% } %>
        </div>
        <div class="flex gap-1 items-center">
            <label for="utcOffset" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Zona Horaria: UTC&nbsp</label>
            <%
            let utcValue = '';
            if (oldData.zonahoraria) {
                const match = oldData.zonahoraria.match(/UTC([+-])(\d+)/);
                if (match) utcValue = match[1] === '-' ? -Number(match[2]) : Number(match[2]);
            }
            %>
            <input type="number" min="-12" max="12" id="utcOffset" class="border border-gray-300 rounded px-2 py-1 text-sm w-12 focus:outline-none focus:border-gray-400" placeholder="00" value="<%= utcValue %>" required>
            <p class="text-sm text-gray-500">:00</p>
            <input type="hidden" id="zonahoraria" name="zonahoraria">
        </div>
        <button type="submit" class="self-start bg-gray-900 hover:bg-gray-700 text-white font-semibold text-sm px-4 py-2 rounded transition-colors">Añadir País</button>
</div>

<!-- Scripts auxiliares -->
<script>
    const form = document.getElementById('addCountryForm');
    form.addEventListener('submit', () => {
        //Limpiar campos vacíos del array de fronteras
        const inputs = Array.from(form.querySelectorAll('input[name="fronteras"]'));
        inputs.forEach(input => {
            if (!input.value.trim()) {
                input.disabled = true;
            }
        });

        //Dar Formato a ZonaHoraria (UTC±HH:00)
        const offset = Number(document.getElementById('utcOffset').value);
        const formattedOffset = String(Math.abs(offset)).padStart(2,'0');
        const finalTimeZone = `UTC${offset >= 0 ? '+' : '-'}${formattedOffset}:00`;
        document.getElementById('zonahoraria').value = finalTimeZone;
    });
</script>