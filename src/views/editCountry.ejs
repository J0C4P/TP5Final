<div class="divide-y divide-black">
    <div>
        <a href="/countries" class="bg-gray-500">Volver al dashboard</a>
    </div>
    <form id="editCountryForm" class="divide-y divide-black">
            <div class="py-2">
            <% if (errors['nombre.oficial']) { %>
                <p class="text-red-500"> ▼ <%= errors['nombre.oficial'] %></p>
                <label for="nombre.oficial" class="font-semibold text-red-700">Nombre Oficial:</label>
                <input type="text" id="nombre.oficial" name="nombre.oficial" class="border" required>
            <% } else { %>
                <label for="nombre.oficial" class="font-semibold">Nombre Oficial:</label>
                <input type="text" id="nombre.oficial" name="nombre.oficial" class="border" value="<%= oldData.nombre.oficial %>" required>
            <% } %>
        </div>
        <div class="py-2">
            <% if (errors['nombre.comun']) { %>
                <p class="text-red-500"> ▼ <%= errors['nombre.comun'] %></p>
                <label for="nombre.comun" class="font-semibold text-red-700">Nombre Común:</label>
                <input type="text" id="nombre.comun" name="nombre.comun" class="border" required>
            <% } else { %>
                <label for="nombre.comun" class="font-semibold">Nombre Común:</label>
                <input type="text" id="nombre.comun" name="nombre.comun" class="border" value="<%= oldData.nombre.comun %>" required>
            <% } %>
        </div>
        <div class="py-2">
            <% if (errors.capital) { %>
                <p class="text-red-500"> ▼ <%= errors.capital %></p>
                <label for="capital" class="font-semibold text-red-700">Capital:</label>
                <input type="text" id="capital" name="capital" class="border" value="<%= oldData.capital %>" required>
            <% } else { %>
                <label for="capital" class="font-semibold">Capital:</label>
                <input type="text" id="capital" name="capital" class="border" value="<%= oldData.capital %>" required>
            <% } %>
        </div>
        <div class="py-2">
            <% if (errors['fronterasItem']) { %>
                <p class="text-red-500"> ▼ <%= errors['fronterasItem'] %></p>
                <label for="fronteras" class="font-semibold text-red-700">Fronteras:</label>
            <% } else { %>
                <label for="fronteras" class="font-semibold">Fronteras:</label>
            <% } %>
            <% const fronteras = oldData.fronteras || [] %>
            <ul>
                <input type="text" id="fronteras" name="fronteras" class="border" placeholder="País Limítrofe 1" value="<%= fronteras[0] || '' %>" required>
                <input type="text" id="fronteras" name="fronteras" class="border" placeholder="País Limítrofe 2" value="<%= fronteras[1] || ''%>">
                <input type="text" id="fronteras" name="fronteras" class="border" placeholder="País Limítrofe 3" value="<%= fronteras[2] || ''%>">
                <input type="text" id="fronteras" name="fronteras" class="border" placeholder="País Limítrofe 4" value="<%= fronteras[3] || ''%>">
                <input type="text" id="fronteras" name="fronteras" class="border" placeholder="País Limítrofe 5" value="<%= fronteras[4] || ''%>">
            </ul>
        </div>
        <div class="py-2">
            <% if (errors.area) { %>
                <p class="text-red-500"> ▼ <%= errors.area %></p>
                <label for="area" class="font-semibold text-red-700">Área:</label>
                <input type="float" id="area" name="area" class="border" value="<%= oldData.area %>" required>
            <% } else { %>
                <label for="area" class="font-semibold">Área:</label>
                <input type="float" id="area" name="area" class="border" value="<%= oldData.area %>" required>
            <% } %>
        </div>
        <div class="py-2">
            <% if (errors.poblacion) { %>
                <p class="text-red-500"> ▼ <%= errors.poblacion %></p>
                <label for="poblacion" class="font-semibold text-red-700">Población:</label>
                <input type="number" id="poblacion" name="poblacion" class="border" value="<%= oldData.poblacion %>" required>
            <% } else { %>
                <label for="poblacion" class="font-semibold">Población:</label>
                <input type="number" min="0" id="poblacion" name="poblacion" class="border" value="<%= oldData.poblacion %>" required>
            <% } %>
        </div>
        <div class="py-2">
            <% if (errors.subregion) { %>
                <p class="text-red-500"> ▼ <%= errors.subregion %></p>
                <label for="subregion" class="font-semibold text-red-700">Sub Región:</label>
                <input type="text" id="subregion" name="subregion" class="border" value="<%= oldData.subregion %>" required>
            <% } else { %>
                <label for="subregion" class="font-semibold">Sub Región:</label>
                <input type="text" id="subregion" name="subregion" class="border" value="<%= oldData.subregion %>" required>
            <% } %>
        </div>
        <div class="flex border py-2">
            <label for="utcOffset" class="font-semibold">Zona Horaria: UTC&nbsp</label>
            <%
            let utcValue = '';
            if (oldData.zonahoraria) {
                const match = oldData.zonahoraria.match(/UTC([+-])(\d+)/);
                if (match) utcValue = match[1] === '-' ? -Number(match[2]) : Number(match[2]);
            }
            %>
            <input type="number" min="-12" max="12" id="utcOffset" class="border w-9" value="<%= utcValue %>" required>
            <p> :00</p>
            <input type="hidden" id="zonahoraria" name="zonahoraria">
        </div>
        <button type="submit" class="bg-blue-500 font-bold">Guardar Cambios</button>
    </form>
</div>
<!-- Scripts auxiliares -->
<script>
    const form = document.getElementById('editCountryForm');
    form.addEventListener('submit', async (event) => {
        event.preventDefault();

        //Limpiar mensajes de errores previos 
        document.querySelectorAll('.error-msg').forEach(el => el.remove());
        form.querySelectorAll('label').forEach(el => el.style.color = '');

        //Limpiar campos vacíos del array de fronteras
        const inputs = Array.from(form.querySelectorAll('input[name="fronteras"]'));
        inputs.forEach(input => {
            if (!input.value.trim()) {
                input.disabled = true;
            }
        });

        //Dar Formato a ZonaHoraria (UTC±HH:00)
        const offset = Number(document.getElementById('utcOffset').value);
        const formattedOffset = String(Math.abs(offset)).padStart(2,'0');
        const finalTimeZone = `UTC${offset >= 0 ? '+' : '-'}${formattedOffset}:00`;
        document.getElementById('zonahoraria').value = finalTimeZone;

        //Formatear data del formulario en un objeto plano para enviarlo como JSON
        const formData = new FormData(form);
        const body = {};
        formData.forEach((value, key) => {
            if (body[key] !== undefined) {
                body[key] = [].concat(body[key], value);
            } else {
                body[key] = value;
            }
        });

        //Enviar Formulario al servidor con fetch a la ruta PUT
        const id = "<%= oldData._id %>";
        const response = await fetch(`/countries/edit/${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(body)
        });

        if (response.ok) {
            window.location.href = '/countries';

        } else if (response.status === 422) {
            //Ante un error de validación, manejar errores presentes en response.json()
            const { errors } = await response.json();
            //Asociar cada error a su campo correspondiente
            const fieldSelectors = {
                'nombre.oficial': { 
                    label: 'label[for="nombre.oficial"]',
                    input: 'input[name="nombre.oficial"]'
                },
                'nombre.comun': { 
                    label: 'label[for="nombre.comun"]',
                    input: 'input[name="nombre.comun"]'
                },
                'capital': {
                    label: 'label[for="capital"]',
                    input: 'input[name="capital"]' 
                },
                'area': {
                    label: 'label[for="area"]',
                    input: 'input[name="area"]'
                },
                'poblacion': {
                    label: 'label[for="poblacion"]',
                    input: 'input[name="poblacion"]'
                },
                'subregion': { 
                    label: 'label[for="subregion"]', 
                    input: 'input[name="subregion"]' 
                },
                'fronterasItem': {
                    label: 'label[for="fronteras"]',
                    input: 'input[name="fronteras"]'
                },
            };
            //<p> auxiliar para mostrar mensaje de error
            for (const [key, selector] of Object.entries(fieldSelectors)) {
                if (errors[key]) {
                    const label = form.querySelector(selector.label);
                    if (label) {
                        const p = document.createElement('p');
                        p.className = 'text-red-800 font-bold';
                        p.textContent = '▼ ' + errors[key];
                        label.parentNode.insertBefore(p, label);
                    }
                    const input = form.querySelector(selector.input);
                    if (input) {
                        input.classList.add('text-red-500', 'font-bold');
                        input.style.borderColor = 'red';
                    }
                }
            }
            //Rehabilitar campos fronteras desactivados previamente
            inputs.forEach(input => input.disabled = false);
        } else {
            alert(`Error al guardar los cambios. Status: ${response.status}`);
        }
    });
</script>