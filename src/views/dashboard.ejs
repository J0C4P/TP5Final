<!-- Dashboard wrapper: flex column filling the main element -->
<div class="flex flex-col h-full">
<!-- Barra de búsqueda y filtros -->
<div class="bg-white border-b border-gray-200 px-4 py-3 shrink-0">
    <div class="flex flex-wrap items-end gap-4">
        <div class="flex flex-col gap-1">
            <label for="filter-search" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Buscar (nombre o capital)</label>
            <input id="filter-search" type="text" placeholder="Nombre o capital..." class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400">
        </div>
        <div class="flex flex-col gap-1">
            <label for="filter-subregion" class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Subregión</label>
            <select id="filter-subregion" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:border-gray-400">
                <option value="">Todas</option>
                <option value="south america">Sudamérica</option>
                <option value="caribbean">Caribe</option>
                <option value="central america">Centroamérica</option>
                <option value="north america">Norteamérica</option>
            </select>
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Población</label>
            <div class="flex items-center gap-1">
                <input id="filter-pobl-min" type="number" min="0" placeholder="Mín" class="border border-gray-300 rounded px-2 py-1 text-sm w-24 focus:outline-none focus:border-gray-400">
                <span class="text-gray-400 text-sm">&ndash;</span>
                <input id="filter-pobl-max" type="number" min="0" placeholder="Máx" class="border border-gray-300 rounded px-2 py-1 text-sm w-24 focus:outline-none focus:border-gray-400">
            </div>
        </div>
        <button id="btn-clear-filters" type="button" class="self-end border border-gray-300 rounded px-3 py-1 text-sm text-gray-600 hover:bg-gray-100 transition-colors">Limpiar</button>
        <button id="btn-export-csv" type="button" class="self-end border border-green-600 rounded px-3 py-1 text-sm text-green-700 font-semibold hover:bg-green-50 transition-colors">Exportar CSV</button>
    </div>
    <p id="filter-count" class="mt-2 text-xs text-gray-500"></p>
</div>
<!-- Dashboard -->
<div id="country-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 p-4 flex-1 overflow-auto content-start" style="min-height: 200px;">
    <% if (countries && countries.length > 0) { %>
    <% countries.forEach(country => { %>
    <% if (country.nombre.oficial) { %>
        <div class="country-card flex flex-col border border-gray-200 rounded-lg p-4 bg-white shadow-sm hover:shadow-md transition-shadow"
             data-nombre="<%= (country.nombre.oficial + ' ' + (country.nombre.comun||'')).toLowerCase() %>"
             data-capital="<%= (country.capital||'').toString().toLowerCase() %>"
             data-subregion="<%= (country.subregion||'').toLowerCase() %>"
             data-poblacion="<%= country.poblacion || 0 %>"
             data-area="<%= country.area || 0 %>"
             data-gini="<%= (country.gini && country.gini.length > 0) ? country.gini[country.gini.length - 1] : '' %>"
             data-fronteras="<%= (country.fronteras && country.fronteras.length > 0) ? country.fronteras.join(' | ') : '' %>"
             data-zonahoraria="<%= country.zonahoraria || '' %>"
             data-nombre-display="<%= country.nombre.oficial %>"
             data-creador="<%= country.creador || '' %>">
            <div class="flex-grow">
                <h5 class="font-semibold text-gray-900 flex items-center gap-1 mb-2">
                    <span><%= country.nombre.oficial %></span>
                    <% if (country.bandera) { %>
                        <span class="text-base"><%= country.bandera %></span>
                    <% } %>
                </h5>
                <% if (country.capital) { %>
                    <p class="text-sm text-gray-600"><span class="font-medium">Capital:</span> <%= country.capital %></p>
                <% } %>
                <% if (country.fronteras && country.fronteras.length > 0) { %>
                    <p class="text-sm text-gray-600"><span class="font-medium">Fronteras:</span> <%= country.fronteras.join(', ') %></p>
                <% } %>
                <% if (country.area) { %>
                    <p class="text-sm text-gray-600"><span class="font-medium">Área:</span> <%= country.area %></p>
                <% } %>
                <% if (country.poblacion) { %>
                    <p class="text-sm text-gray-600"><span class="font-medium">Población:</span> <%= country.poblacion %></p>
                <% } %>
                <% if (country.zonahoraria) { %>
                    <p class="text-sm text-gray-600"><span class="font-medium">Zona horaria:</span> <%= country.zonahoraria %></p>
                <% } %>
                <% if (country.creador) { %>
                    <p class="text-sm text-gray-600"><span class="font-medium">Creador:</span> <%= country.creador %></p>
                <% } %>
            </div>
            <div class="flex gap-2 mt-3 pt-3 border-t border-gray-100">
                <a href="/countries/edit/<%= country._id %>" class="flex-1 text-center bg-amber-400 hover:bg-amber-500 text-gray-900 font-semibold text-xs px-2 py-1 rounded transition-colors">EDITAR</a>
                <button type="button" class="flex-1 bg-red-500 hover:bg-red-600 text-white font-semibold text-xs px-2 py-1 rounded transition-colors"
                onclick="confirmDelete('<%= country._id%>','<%= country.nombre.oficial %>')">
                    ELIMINAR
                </button>
            </div>
        </div>
    <% } %>
    <% }) %>
    <% } else { %>
        <div class="col-span-full text-center py-12 text-gray-400">
            <p>No se encontraron países.</p>
        </div>
    <% } %>
</div>
<!-- Controles de Paginación -->
<div id="pagination-bar" class="bg-white border-t border-gray-100 px-4 py-2 flex items-center justify-between gap-4 hidden shrink-0">
    <span id="pagination-info" class="text-xs text-gray-500"></span>
    <div class="flex items-center gap-1">
        <button id="btn-first" type="button"
            class="px-2 py-1 text-xs rounded border border-gray-300 text-gray-600 hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            title="Primera página">«</button>
        <button id="btn-prev" type="button"
            class="px-2 py-1 text-xs rounded border border-gray-300 text-gray-600 hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            title="Página anterior">‹</button>
        <span id="pagination-pages" class="flex gap-1"></span>
        <button id="btn-next" type="button"
            class="px-2 py-1 text-xs rounded border border-gray-300 text-gray-600 hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            title="Página siguiente">›</button>
        <button id="btn-last" type="button"
            class="px-2 py-1 text-xs rounded border border-gray-300 text-gray-600 hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
            title="Última página">»</button>
    </div>
</div>
<!-- Fila de Totales -->
<div id="totals-bar" class="bg-white border-t border-gray-200 px-4 py-3 flex flex-wrap justify-around gap-6 shrink-0 mt-auto">
    <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Población Total</p>
        <p id="total-poblacion" class="text-lg font-bold text-gray-900">0</p>
    </div>
    <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Área Total</p>
        <p id="total-area" class="text-lg font-bold text-gray-900">0</p>
    </div>
    <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide font-semibold">Índice de Gini Promedio</p>
        <p id="total-gini" class="text-lg font-bold text-gray-900">0</p>
    </div>
</div>
</div><!-- end dashboard wrapper -->

<!-- Scripts Auxiliares -->
<script>
    const cards = Array.from(document.querySelectorAll('.country-card'));
    const totalCount = cards.length;

    //Paginación
    let currentPage = 1;
    let filteredCards = [];   // cards that pass the current filter
    let cardsPerPage  = 8;    // will be recalculated dynamically
    let _cachedCardH = 0; // cached once from a real visible card

    //Calcular cuantas cards caben por página 
    function computeCardsPerPage() {
        //Alturas de elementos de la página
        const navbar     = document.querySelector('nav') || document.querySelector('header');
        const filterBar  = document.querySelector('.bg-white.border-b');
        const pagBar     = document.getElementById('pagination-bar');
        const totalsBar  = document.getElementById('totals-bar');

        const navH     = navbar    ? navbar.offsetHeight    : 56;
        const filterH  = filterBar ? filterBar.offsetHeight : 60;
        // Use 0 when pagination bar is hidden (it takes no space)
        const pagH     = pagBar && !pagBar.classList.contains('hidden') ? pagBar.offsetHeight : 0;
        const totalsH  = totalsBar ? totalsBar.offsetHeight : 64;

        const availableH = window.innerHeight - navH - filterH - pagH - totalsH - 32; // 32px padding

        //Calcular altura de las cards — sólo desde una card VISIBLE para evitar offsetHeight=0
        if (!_cachedCardH) {
            // First try: find any currently visible card
            const visibleCard = Array.from(document.querySelectorAll('.country-card'))
                                     .find(c => c.offsetHeight > 0);
            // Fallback: first card in DOM (page just loaded, all visible)
            const sampleCard = visibleCard || document.querySelector('.country-card');
            if (sampleCard && sampleCard.offsetHeight > 0) {
                _cachedCardH = sampleCard.offsetHeight + 16; // 16 = gap-4
            }
        }
        const cardH = _cachedCardH || 180; // safe default

        //Calcular cuántas columnas hay según el ancho
        const gridEl = document.getElementById('country-list');
        const gridW  = gridEl ? gridEl.offsetWidth : window.innerWidth;
        let cols = 1;
        if (gridW >= 1280) cols = 4;        // xl:grid-cols-4
        else if (gridW >= 1024) cols = 3;   // lg:grid-cols-3
        else if (gridW >= 640)  cols = 2;   // sm:grid-cols-2

        const rows = Math.max(1, Math.floor(availableH / cardH));
        return Math.max(cols, rows * cols);  // at least one full row
    }

    //Renderizar la página actual según los filtros y la paginación
    function renderPage() {
        const start = (currentPage - 1) * cardsPerPage;
        const end   = start + cardsPerPage;

        cards.forEach(card => { card.style.display = 'none'; });
        filteredCards.forEach((card, i) => {
            card.style.display = (i >= start && i < end) ? '' : 'none';
        });

        updatePaginationUI();
    }

    //Controles de la barra de paginación (números, botones activos/desactivados, info)
    function updatePaginationUI() {
        const total     = filteredCards.length;
        const totalPages = Math.ceil(total / cardsPerPage) || 1;
        const paginationBar = document.getElementById('pagination-bar');

        if (totalPages <= 1) {
            paginationBar.classList.add('hidden');
            return;
        }
        paginationBar.classList.remove('hidden');

        const start = Math.min((currentPage - 1) * cardsPerPage + 1, total);
        const end   = Math.min(currentPage * cardsPerPage, total);
        document.getElementById('pagination-info').textContent =
            `Página ${currentPage} de ${totalPages} · mostrando ${start}–${end} de ${total}`;

        //Prev/Siguiente/Primera/Última página
        document.getElementById('btn-first').disabled = currentPage === 1;
        document.getElementById('btn-prev').disabled  = currentPage === 1;
        document.getElementById('btn-next').disabled  = currentPage === totalPages;
        document.getElementById('btn-last').disabled  = currentPage === totalPages;

        //Números de página
        const pagesEl = document.getElementById('pagination-pages');
        pagesEl.innerHTML = '';

        const maxVisible = 7;
        let pageStart = Math.max(1, currentPage - Math.floor(maxVisible / 2));
        let pageEnd   = Math.min(totalPages, pageStart + maxVisible - 1);
        if (pageEnd - pageStart < maxVisible - 1) {
            pageStart = Math.max(1, pageEnd - maxVisible + 1);
        }

        for (let p = pageStart; p <= pageEnd; p++) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.textContent = p;
            btn.title = `Página ${p}`;
            const isActive = p === currentPage;
            btn.className = [
                'px-2 py-1 text-xs rounded border transition-colors',
                isActive
                    ? 'bg-gray-800 text-white border-gray-800 font-semibold cursor-default'
                    : 'border-gray-300 text-gray-600 hover:bg-gray-100'
            ].join(' ');
            if (!isActive) btn.addEventListener('click', () => goToPage(p));
            pagesEl.appendChild(btn);
        }
    }

    //Función para cambiar de página
    function goToPage(p) {
        const totalPages = Math.ceil(filteredCards.length / cardsPerPage) || 1;
        currentPage = Math.max(1, Math.min(p, totalPages));
        renderPage();
    }

    document.getElementById('btn-first').addEventListener('click', () => goToPage(1));
    document.getElementById('btn-prev').addEventListener('click',  () => goToPage(currentPage - 1));
    document.getElementById('btn-next').addEventListener('click',  () => goToPage(currentPage + 1));
    document.getElementById('btn-last').addEventListener('click',  () => {
        goToPage(Math.ceil(filteredCards.length / cardsPerPage));
    });

    //Función Filtros y actualización de totales
    function applyFilters() {
        const search   = document.getElementById('filter-search').value.trim().toLowerCase();
        const subregion = document.getElementById('filter-subregion').value;
        const poblMin  = Number(document.getElementById('filter-pobl-min').value) || 0;
        const poblMax  = Number(document.getElementById('filter-pobl-max').value) || Infinity;

        //Calcular cuántas cards mostrar por página según el tamaño actual de la ventana
        cardsPerPage = computeCardsPerPage();

        let poblacionTotal = 0;
        let areaTotal      = 0;
        let giniTotal      = 0;
        let giniCount      = 0;

        filteredCards = [];

        cards.forEach(card => {
            const matchSearch   = !search || card.dataset.nombre.includes(search) || card.dataset.capital.includes(search);
            const matchSubregion = !subregion || card.dataset.subregion === subregion;
            const pobl          = Number(card.dataset.poblacion);
            const matchPobl     = pobl >= poblMin && pobl <= poblMax;
            const show          = matchSearch && matchSubregion && matchPobl;

            //Ocultar todas las cards inicialmente, luego mostrar solo las que coinciden con los filtros
            card.style.display = 'none';

            if (show) {
                filteredCards.push(card);

                //Acumular totales para las cards que pasan los filtros
                poblacionTotal += pobl;
                const area = Number(card.dataset.area);
                if (!isNaN(area)) areaTotal += area;
                const gini = Number(card.dataset.gini);
                if (!isNaN(gini) && card.dataset.gini !== '') { giniTotal += gini; giniCount++; }
            }
        });

        //Resetear paginado 
        currentPage = 1;
        renderPage();

        //Actualizar contador de resultados
        const countEl = document.getElementById('filter-count');
        if (filteredCards.length === totalCount) {
            countEl.textContent = '';
        } else {
            countEl.textContent = `Mostrando ${filteredCards.length} de ${totalCount} países`;
        }

        //Calcular y mostrar totales
        document.getElementById('total-poblacion').textContent =
            poblacionTotal.toLocaleString('es-AR');
        document.getElementById('total-area').textContent =
            areaTotal.toLocaleString('es-AR', { maximumFractionDigits: 2 }) + ' km²';
        document.getElementById('total-gini').textContent =
            giniCount > 0 ? (giniTotal / giniCount).toFixed(2) : 'N/D';
    }

    //Recalcular cards por página al redimensionar
    let resizeTimer;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
            cardsPerPage = computeCardsPerPage();
            
            const totalPages = Math.ceil(filteredCards.length / cardsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;
            renderPage();
        }, 150);
    });

    //Enlazar filtros a la función de renderizado
    ['filter-search','filter-subregion','filter-pobl-min','filter-pobl-max'].forEach(
        id => document.getElementById(id).addEventListener('input', applyFilters)
    );

    document.getElementById('btn-clear-filters').addEventListener('click', () => {
        ['filter-search','filter-subregion','filter-pobl-min','filter-pobl-max']
            .forEach(id => document.getElementById(id).value = '');
        applyFilters();
    });

    //Renderizado inicial
    if (document.readyState === 'complete') {
        applyFilters();
    } else {
        window.addEventListener('load', applyFilters);
    }

    //Botón Eliminar país
    async function confirmDelete(id, nombre) {
        console.log('Iniciando eliminación de país con ID:', id);
        const confirmed = confirm(`¿Eliminar a ${nombre}? Esta acción no se puede deshacer.`);
        if (!confirmed) return;

        try {
            const response = await fetch(`/countries/eliminar/${id}`, { method: 'DELETE' });

            if (response.ok) {
                window.location.reload();
            } else {
                let errorMsg = 'No se pudo eliminar el país.(Dashboard)';
                try {
                    const body = await response.json();
                    if (body.mensaje) errorMsg += '\n' + body.mensaje;
                    if (body.error)   errorMsg += '\n' + body.error;
                } catch (e) {
                    errorMsg += '\nError desconocido (status ' + response.status + ')';
                }
                alert(errorMsg);
                console.error('Delete error:', response.status, response.statusText);
            }
        } catch (err) {
            alert('Error de conexión: ' + err.message);
            console.error('Fetch error:', err);
        }
    }

    //Función Exportar a CSV
    function exportCSV() {

        //Formato de fila de encabezados
        const headers = ['Nombre Oficial','Capital','Subregión','Población','Área (km²)','Gini','Fronteras','Zona Horaria','Creador'];

        //Construir filas de datos de los países filtrados
        const rows = filteredCards.map(card => [
            card.dataset.nombreDisplay  || '',   // Nombre oficial (casing original)
            card.dataset.capital        || '',   // Capital
            card.dataset.subregion      || '',   // Subregión
            card.dataset.poblacion      || '',   // Población
            card.dataset.area           || '',   // Área en km²
            card.dataset.gini           || '',   // Último índice de Gini registrado
            card.dataset.fronteras      || '',   // Fronteras separadas por " | "
            card.dataset.zonahoraria    || '',   // Zona horaria
            card.dataset.creador        || ''    // Usuario que creó el registro
        ]);

        //Formateo celdas con comas, comillas ó '\n'
        const escapeCell = val => {
            const str = String(val);
            return (str.includes(',') || str.includes('"') || str.includes('\n'))
                ? '"' + str.replace(/"/g, '""') + '"'
                : str;
        };

        //Separar celdas y filas
        const csvContent = [headers, ...rows]
            .map(row => row.map(escapeCell).join(','))
            .join('\r\n');

        //Crear 'Blob' y enlace de descarga
        const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });


        const url  = URL.createObjectURL(blob);
        const link = document.createElement('a');
        const timestamp = new Date().toISOString().slice(0, 10);
        link.href = url;
        link.download = `paises_${timestamp}.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        //Liberar memoria
        URL.revokeObjectURL(url);
    }

    //Botón de Exportar CSV
    document.getElementById('btn-export-csv').addEventListener('click', exportCSV);
</script>
