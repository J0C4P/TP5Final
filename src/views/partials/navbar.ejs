<nav class="bg-white border-b border-gray-200">
    <div class="flex items-center gap-2 px-4 py-2">
        <% navbarLinks.forEach(link => { %>
            <a href="<%= link.href %>" class="flex items-center gap-1 px-3 py-1 rounded text-sm text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">
                <img src="<%= link.icon %>" alt="<%= link.text %> Icon" class="w-12 h-12">
                <span><%= link.text %></span>
            </a>
        <% }); %>
    </div>
</nav>